//1.2 -- Multilevel inheritance


class Vehicle{
public:
    void start(){
        cout<< "Vehicle Start"<< "\n";
    }
    
};


class Car : public Vehicle{
public:
    void drive(){
        cout<<"Car is running "<< "\n";
    }
};


class SpeedoMeter : public Car{
public:
void speed(){
    cout<<"Car is running at 60km/h";
}
};


int main(){
    SpeedoMeter obj1;
    obj1.drive();
    obj1.start();
    obj1.speed();
}


