//customer support IVR system
//1 for support
//2 for billing
//3 for technical issues
//4 for talk to the agent

#include<iostream>
using namespace std;
 
int main(){
    int choice;
    cin>>choice;
    
    switch (choice){
        case 1:
        cout<<"Tranferring call to the customer support";
        break;
        case 2:
        cout<<"Tranferring call to billing and accounts";
        break;
        case 3:
        cout<<"connecting to technical  help desk";
        break;
        case 4:
        cout<<"connecting call to the agent";
        break;
        
        default :
        cout<<"Invalid section";
        break;
    }
}
