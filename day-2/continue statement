//continue statement
//print 1 to n and avoid those number which are divisible by 3

#include<iostream>
using namespace std;
int main(){
    int a; 
    cout<<"enter the number";
    cin>>a;
    
    for(int i=1 ; i<=a; i++){
        if(i %3 ==0){
            continue;
        }
        cout<<i<<" ";
    }
    
    return 0;
    
}
